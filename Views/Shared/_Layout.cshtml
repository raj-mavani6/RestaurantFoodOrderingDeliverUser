<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Delivery User Panel</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css">
</head>
<body>
    <!-- Navigation Header -->
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="@Url.Action("Dashboard", "Home")">
                <i class="fas fa-motorcycle me-2"></i>Delivery Partner
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                            <i class="fas fa-user-circle me-1"></i>Account
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                            <li><a class="dropdown-item" href="@Url.Action("Profile", "Home")"><i class="fas fa-user me-2"></i>Profile</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="@Url.Action("Logout", "Auth")">
                                <i class="fas fa-sign-out-alt me-2"></i>Logout
                            </a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <!-- Sidebar Logo Header -->
        <div class="sidebar-logo">
            <i class="fas fa-utensils"></i>
            <span>Tasty Bites</span>
        </div>
        
        <!-- Sidebar Navigation -->
        <nav class="sidebar-nav">
            <ul class="sidebar-menu">
                <li class="sidebar-item">
                    <a href="@Url.Action("Dashboard", "Home")" class="sidebar-link">
                        <i class="fas fa-home"></i>
                        <span>Dashboard</span>
                    </a>
                </li>
                <li class="sidebar-item">
                    <a href="@Url.Action("Attendance", "Home")" class="sidebar-link">
                        <i class="fas fa-clipboard-check"></i>
                        <span>Attendance</span>
                    </a>
                </li>
                <li class="sidebar-item">
                    <a href="@Url.Action("Calendar", "Home")" class="sidebar-link">
                        <i class="fas fa-calendar-alt"></i>
                        <span>Calendar</span>
                    </a>
                </li>
                <li class="sidebar-item">
                    <a href="@Url.Action("DeliveryOrders", "Home")" class="sidebar-link">
                        <i class="fas fa-truck"></i>
                        <span>Orders</span>
                    </a>
                </li>
                <li class="sidebar-item">
                    <a href="@Url.Action("Earnings", "Home")" class="sidebar-link">
                        <i class="fas fa-wallet"></i>
                        <span>Earnings</span>
                    </a>
                </li>
                <li class="sidebar-item has-submenu">
                    <a href="#" class="sidebar-link submenu-toggle">
                        <i class="fas fa-file-alt"></i>
                        <span>Leave</span>
                        <i class="fas fa-chevron-right submenu-arrow"></i>
                    </a>
                    <ul class="sidebar-submenu">
                        <li>
                            <a href="@Url.Action("ApplyLeaves", "Home")" class="sidebar-link">
                                <i class="fas fa-plus-circle"></i>
                                <span>Apply Leave</span>
                            </a>
                        </li>
                        <li>
                            <a href="@Url.Action("ViewLeaves", "Home")" class="sidebar-link">
                                <i class="fas fa-list-alt"></i>
                                <span>My Leaves</span>
                            </a>
                        </li>
                    </ul>
                </li>
                <li class="sidebar-item">
                    <a href="@Url.Action("Rules", "Home")" class="sidebar-link">
                        <i class="fas fa-book"></i>
                        <span>Rules</span>
                    </a>
                </li>
            </ul>
        </nav>
        
        <!-- Sidebar Footer - User Section -->
        <div class="sidebar-footer">
            <div class="sidebar-user">
                <i class="fas fa-user-circle"></i>
                <span>Delivery Partner</span>
            </div>
            <a href="@Url.Action("Logout", "Auth")" class="sidebar-logout">
                <i class="fas fa-sign-out-alt"></i>
                <span>Logout</span>
            </a>
        </div>
    </aside>

    <!-- Main Content Wrapper -->
    <div class="main-wrapper">
        <!-- Main Content -->
        <main class="main-content">
            @RenderBody()
        </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container-fluid">
            <div class="row">
                <div class="col-lg-4 col-md-6 mb-4">
                    <h5><i class="fas fa-motorcycle"></i>Delivery Partner</h5>
                    <p>Professional delivery service management system for food ordering platform. Making food delivery faster and more efficient.</p>
                    <div class="footer-social">
                        <a href="#" title="Facebook"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" title="Twitter"><i class="fab fa-twitter"></i></a>
                        <a href="#" title="Instagram"><i class="fab fa-instagram"></i></a>
                        <a href="#" title="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
                    </div>
                </div>
                <div class="col-lg-4 col-md-6 mb-4">
                    <h5>Quick Links</h5>
                    <ul class="list-unstyled">
                        <li><a href="@Url.Action("Dashboard", "Home")"><i class="fas fa-home me-2"></i>Dashboard</a></li>
                        <li><a href="@Url.Action("Rules", "Home")"><i class="fas fa-book me-2"></i>Rules</a></li>
                        <li><a href="@Url.Action("About", "Home")"><i class="fas fa-info-circle me-2"></i>About</a></li>
                        <li><a href="@Url.Action("Contact", "Home")"><i class="fas fa-envelope me-2"></i>Contact</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 col-md-6 mb-4">
                    <h5>Contact Us</h5>
                    <p>
                        <i class="fas fa-envelope me-2"></i>support@tastybites.com
                    </p>
                    <p>
                        <i class="fas fa-phone me-2"></i>+91 1234567890
                    </p>
                    <p>
                        <i class="fas fa-map-marker-alt me-2"></i>Mumbai, India
                    </p>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <div class="d-flex justify-content-between align-items-center flex-wrap">
                <p class="mb-0">&copy; 2025 Restaurant Food Ordering System. All rights reserved.</p>
                <div class="footer-links">
                    <a href="@Url.Action("PrivacyPolicy", "Home")">Privacy Policy</a>
                    <span class="mx-2">and</span>
                    <a href="@Url.Action("TermsOfService", "Home")">Terms of Service</a>
                </div>
            </div>
        </div>
    </footer>
    </div> <!-- Close main-wrapper -->

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Custom JS -->
    <script src="~/js/site.js"></script>
    
    <!-- Submenu Toggle Script -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Submenu toggle
            const submenuToggles = document.querySelectorAll('.submenu-toggle');
            submenuToggles.forEach(function(toggle) {
                toggle.addEventListener('click', function(e) {
                    e.preventDefault();
                    const parent = this.parentElement;
                    parent.classList.toggle('open');
                });
            });
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
