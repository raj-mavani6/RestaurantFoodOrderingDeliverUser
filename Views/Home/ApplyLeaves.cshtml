@{
    ViewData["Title"] = "Apply for Leave";
}

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="page-heading">
                <i class="fas fa-calendar-alt me-2"></i>Apply for Leave
            </h2>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Dashboard", "Home")" class="btn btn-outline-primary btn-sm">
                <i class="fas fa-arrow-left me-1"></i>Back to Dashboard
            </a>
        </div>
    </div>

    <div class="row">
        <!-- Leave Application Form -->
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary-custom text-white">
                    <h5 class="mb-0"><i class="fas fa-file-alt me-2"></i>Leave Request Form</h5>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(ViewBag.SuccessMessage))
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle me-2"></i>
                            @ViewBag.SuccessMessage
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            @ViewBag.ErrorMessage
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form method="post" asp-action="ApplyLeaves" id="leaveForm">
                        <!-- Leave Type -->
                        <div class="mb-3">
                            <label for="leaveType" class="form-label">
                                <i class="fas fa-list me-2"></i>Leave Type *
                            </label>
                            <select class="form-select" id="leaveType" name="leaveType" required>
                                <option value="">-- Select Leave Type --</option>
                                <option value="SingleDay">Single Day Leave</option>
                                <option value="MultipleDay">Multiple Day Leave</option>
                                <option value="PastDay">Past Day Leave</option>
                                <option value="Emergency">Emergency Leave</option>
                            </select>
                            <small id="leaveTypeHint" class="text-muted"></small>
                        </div>

                        <!-- Start Date -->
                        <div class="mb-3">
                            <label for="startDate" class="form-label">
                                <i class="fas fa-calendar-check me-2"></i>Start Date *
                            </label>
                            <input type="date" class="form-control" id="startDate" name="startDate" required>
                        </div>

                        <!-- End Date -->
                        <div class="mb-3" id="endDateContainer">
                            <label for="endDate" class="form-label">
                                <i class="fas fa-calendar-times me-2"></i>End Date *
                            </label>
                            <input type="date" class="form-control" id="endDate" name="endDate" required>
                        </div>

                        <!-- Number of Days -->
                        <div class="mb-3">
                            <label for="numberOfDays" class="form-label">
                                <i class="fas fa-hourglass-half me-2"></i>Number of Days
                            </label>
                            <input type="number" class="form-control" id="numberOfDays" name="numberOfDays" 
                                   readonly placeholder="Auto-calculated">
                        </div>

                        <!-- Reason -->
                        <div class="mb-3">
                            <label for="reason" class="form-label">
                                <i class="fas fa-comment me-2"></i>Reason for Leave *
                            </label>
                            <textarea class="form-control" id="reason" name="reason" rows="4" 
                                      placeholder="Please provide a detailed reason for your leave request" required></textarea>
                        </div>

                        <!-- Buttons -->
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary-custom">
                                <i class="fas fa-paper-plane me-2"></i>Submit Request
                            </button>
                            <button type="reset" class="btn btn-outline-secondary">
                                <i class="fas fa-redo me-2"></i>Clear
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Leave Balance -->
        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="fas fa-chart-pie me-2"></i>Leave Types Info</h5>
                </div>
                <div class="card-body">
                    <div class="leave-info-item mb-3 p-2 border-start border-4 border-primary">
                        <strong><i class="fas fa-calendar-day me-2"></i>Single Day Leave</strong>
                        <p class="mb-0 small text-muted">Apply for exactly 1 day leave</p>
                    </div>

                    <div class="leave-info-item mb-3 p-2 border-start border-4 border-warning">
                        <strong><i class="fas fa-calendar-week me-2"></i>Multiple Day Leave</strong>
                        <p class="mb-0 small text-muted">Apply for 2 or more days leave</p>
                    </div>

                    <div class="leave-info-item mb-3 p-2 border-start border-4 border-secondary">
                        <strong><i class="fas fa-history me-2"></i>Past Day Leave</strong>
                        <p class="mb-0 small text-muted">Apply for missed attendance (past dates only)</p>
                    </div>

                    <div class="leave-info-item p-2 border-start border-4 border-danger">
                        <strong><i class="fas fa-exclamation-triangle me-2"></i>Emergency Leave</strong>
                        <p class="mb-0 small text-muted">For urgent situations, any date allowed</p>
                    </div>
                </div>
            </div>

            <!-- Important Notes -->
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Important Notes</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <i class="fas fa-check text-success me-2"></i>
                            <small>Single Day Leave: Start and End date must be same</small>
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-check text-success me-2"></i>
                            <small>Multiple Day Leave: Minimum 2 days required</small>
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-check text-success me-2"></i>
                            <small>Past Day Leave: Only past dates allowed</small>
                        </li>
                        <li>
                            <i class="fas fa-check text-success me-2"></i>
                            <small>Emergency Leave: Requires manager approval</small>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

