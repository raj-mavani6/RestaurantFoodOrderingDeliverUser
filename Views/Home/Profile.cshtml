        overflow: hidden;
        position: sticky;
        top: 100px;
    }
    
    .profile-sidebar-header {
        background: linear-gradient(135deg, var(--primary-color, #007bff) 0%, #0056b3 100%);
        color: white;
        padding: 25px;
        text-align: center;
    }
    
    .profile-avatar {
        font-size: 4rem;
        margin-bottom: 10px;
    }
    
    .profile-sidebar-header h5 {
        margin-bottom: 10px;
    }
    
    .profile-nav {
        padding: 10px 0;
    }
    
    .profile-nav-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 20px;
        color: #333;
