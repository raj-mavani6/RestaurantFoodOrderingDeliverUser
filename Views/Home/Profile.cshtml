        width: 20px;
        text-align: center;
    }
    
    .profile-section {
        display: none;
    }
    
    .profile-section.active {
        display: block;
    }
    
    .section-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 15px rgba(0,0,0,0.1);
        overflow: hidden;
    }
    
    .section-header {
        padding: 20px 25px;
        border-bottom: 1px solid #eee;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .section-header h4 {
        margin: 0;
        font-size: 1.25rem;
    }
    
    .section-body {
        padding: 25px;
    }
    
    .info-group {
        margin-bottom: 20px;
    }
    
    .info-group label {
        color: #666;
        font-size: 0.85rem;
        font-weight: 500;
        display: block;
