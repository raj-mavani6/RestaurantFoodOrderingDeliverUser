@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-md-10 mx-auto">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="fas fa-shield-alt me-2"></i>Privacy Policy</h4>
                </div>
                <div class="card-body">
                    <p class="text-muted">Last updated: December 2025</p>

                    <h5>1. Information We Collect</h5>
                    <p>We collect information you provide directly to us, including:</p>
                    <ul>
                        <li>Personal identification information (name, email, phone number)</li>
                        <li>Government-issued ID for verification</li>
                        <li>Vehicle registration details</li>
                        <li>Bank account information for payments</li>
                        <li>Location data during active deliveries</li>
                    </ul>

                    <h5>2. How We Use Your Information</h5>
                    <p>We use the information we collect to:</p>
                    <ul>
                        <li>Process and manage your delivery partner account</li>
                        <li>Assign and manage delivery orders</li>
                        <li>Process payments and earnings</li>
                        <li>Communicate important updates and notifications</li>
                        <li>Improve our services and user experience</li>
                        <li>Ensure safety and security of deliveries</li>
                    </ul>

                    <h5>3. Information Sharing</h5>
                    <p>We may share your information with:</p>
                    <ul>
                        <li>Customers (limited contact info for delivery coordination)</li>
                        <li>Restaurant partners (for order fulfillment)</li>
                        <li>Payment processors (for earnings disbursement)</li>
                        <li>Law enforcement (when legally required)</li>
                    </ul>

                    <h5>4. Data Security</h5>
                    <p>We implement appropriate security measures to protect your personal information against unauthorized access, alteration, disclosure, or destruction.</p>

                    <h5>5. Your Rights</h5>
                    <p>You have the right to:</p>
                    <ul>
                        <li>Access your personal data</li>
                        <li>Request correction of inaccurate data</li>
                        <li>Request deletion of your data</li>
                        <li>Opt-out of marketing communications</li>
                    </ul>

                    <h5>6. Location Data</h5>
                    <p>We collect location data only during active delivery hours to facilitate order assignments and track delivery progress. You can disable location services when not on duty.</p>

                    <h5>7. Data Retention</h5>
                    <p>We retain your personal information for as long as your account is active or as needed to provide services. Financial records are retained as required by law.</p>

                    <h5>8. Contact Us</h5>
                    <p>For privacy-related queries, contact us at:</p>
                    <p><strong>Email:</strong> privacy@tastybites.com<br>
                    <strong>Phone:</strong> +91 1800-123-4567</p>
                </div>
            </div>
        </div>
    </div>
</div>
