@model IEnumerable<RestaurantFoodOrderingDeliverUser.Models.Leave>

@{
    ViewData["Title"] = "View Leave Requests";
}

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="page-heading">
                <i class="fas fa-file-alt me-2"></i>Leave Requests
            </h2>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("ApplyLeaves", "Home")" class="btn btn-primary-custom btn-sm me-2">
                <i class="fas fa-plus me-1"></i>Apply New Leave
            </a>
            <a href="@Url.Action("Dashboard", "Home")" class="btn btn-outline-primary btn-sm">
                <i class="fas fa-arrow-left me-1"></i>Back
            </a>
        </div>
    </div>

    <!-- Filter Tabs -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-outline-primary active" onclick="filterLeaves('all')">
                    <i class="fas fa-list me-1"></i>All
                </button>
                <button type="button" class="btn btn-outline-success" onclick="filterLeaves('Approved')">
                    <i class="fas fa-check-circle me-1"></i>Approved
                </button>
                <button type="button" class="btn btn-outline-warning" onclick="filterLeaves('Pending')">
                    <i class="fas fa-hourglass-half me-1"></i>Pending
                </button>
                <button type="button" class="btn btn-outline-danger" onclick="filterLeaves('Rejected')">
                    <i class="fas fa-times-circle me-1"></i>Rejected
                </button>
            </div>
        </div>
    </div>

    <!-- Leave Requests -->
    <div class="row">
        @if (Model != null && Model.Count() > 0)
        {
            @foreach (var leave in Model)
            {
                <div class="col-md-6 mb-3">
                    <div class="leave-card">
                        <div class="leave-card-header">
                            <div class="leave-type-badge">
                                @if (leave.LeaveType == "SingleDay")
                                {
                                    <span class="badge bg-primary">📅 Single Day Leave</span>
                                }
                                else if (leave.LeaveType == "MultipleDay")
                                {
                                    <span class="badge bg-warning text-dark">📆 Multiple Day Leave</span>
                                }
                                else if (leave.LeaveType == "PastDay")
                                {
                                    <span class="badge bg-secondary">⏪ Past Day Leave</span>
                                }
                                else if (leave.LeaveType == "Emergency")
                                {
                                    <span class="badge bg-danger">🚨 Emergency Leave</span>
                                }
                                else
                                {
                                    <span class="badge bg-info">📝 @leave.LeaveType</span>
                                }
                            </div>
                            <div class="leave-status">
                                @if (leave.Status == "Approved")
                                {
                                    <span class="badge bg-success">✓ Approved</span>
                                }
                                else if (leave.Status == "Pending")
                                {
                                    <span class="badge bg-warning">⏳ Pending</span>
                                }
                                else if (leave.Status == "Rejected")
                                {
                                    <span class="badge bg-danger">✗ Rejected</span>
                                }
                            </div>
                        </div>

                        <div class="leave-card-body">
                            <div class="leave-dates">
                                <div class="date-item">
                                    <small class="text-muted">From</small>
                                    <h6>@leave.StartDate.ToString("dd MMM yyyy")</h6>
                                </div>
                                <div class="date-separator">
                                    <i class="fas fa-arrow-right"></i>
                                </div>
                                <div class="date-item">
                                    <small class="text-muted">To</small>
                                    <h6>@leave.EndDate.ToString("dd MMM yyyy")</h6>
                                </div>
                            </div>

                            <div class="leave-details mt-3">
                                <p class="mb-2">
                                    <strong>Reason:</strong> @leave.Reason
                                </p>
                                <p class="mb-2">
                                    <strong>Applied on:</strong> @leave.AppliedDate.ToString("dd MMM yyyy, hh:mm tt")
                                </p>

                                @if (leave.Status == "Approved")
                                {
                                    <p class="mb-0">
                                        <strong>Approved by:</strong> @leave.ApprovedBy
                                        <br>
                                        @if (leave.ApprovedDate.HasValue)
                                        {
                                            <small class="text-muted">@leave.ApprovedDate.Value.ToString("dd MMM yyyy")</small>
                                        }
                                    </p>
                                }
                                else if (leave.Status == "Rejected" && !string.IsNullOrEmpty(leave.AdminNotes))
                                {
                                    <p class="mb-0">
                                        <strong>Rejection Reason:</strong> @leave.AdminNotes
                                    </p>
                                }
                            </div>
                        </div>

                        <div class="leave-card-footer">
                            @if (leave.Status == "Pending")
                            {
                                <button class="btn btn-sm btn-outline-danger" onclick="cancelLeave(@leave.LeaveId)">
                                    <i class="fas fa-trash me-1"></i>Cancel Request
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-secondary" disabled>
                                    <i class="fas fa-lock me-1"></i>@leave.Status
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-md-12">
                <div class="alert alert-info text-center py-5">
                    <i class="fas fa-inbox" style="font-size: 3rem; opacity: 0.5;"></i>
                    <h5 class="mt-3">No Leave Requests</h5>
                    <p class="text-muted">You haven't applied for any leaves yet.</p>
                    <a href="@Url.Action("ApplyLeaves", "Home")" class="btn btn-primary-custom btn-sm">
                        <i class="fas fa-plus me-1"></i>Apply Now
                    </a>
                </div>
            </div>
        }
    </div>

    <!-- Leave Policy -->
    <div class="row mt-5">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0"><i class="fas fa-book me-2"></i>Leave Types Guide</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <h6><i class="fas fa-calendar-day text-primary me-2"></i>Single Day Leave</h6>
                            <p class="small">Apply for exactly 1 day. Best for short absences like appointments.</p>
                        </div>
                        <div class="col-md-3">
                            <h6><i class="fas fa-calendar-week text-warning me-2"></i>Multiple Day Leave</h6>
                            <p class="small">Apply for 2+ days. Use for vacations or extended personal time.</p>
                        </div>
                        <div class="col-md-3">
                            <h6><i class="fas fa-history text-secondary me-2"></i>Past Day Leave</h6>
                            <p class="small">For missed attendance on past dates. Requires valid reason.</p>
                        </div>
                        <div class="col-md-3">
                            <h6><i class="fas fa-exclamation-triangle text-danger me-2"></i>Emergency Leave</h6>
                            <p class="small">For urgent situations. Any date allowed. Quick approval needed.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function filterLeaves(status) {
        // Update active button
        document.querySelectorAll('.btn-group .btn').forEach(btn => {
            btn.classList.remove('active');
        });
        event.target.classList.add('active');

        // Filter leave cards
        const cards = document.querySelectorAll('.leave-card');
        cards.forEach(card => {
            if (status === 'all') {
                card.parentElement.style.display = 'block';
            } else {
                const cardStatus = card.querySelector('.leave-status .badge').textContent.trim();
                if (cardStatus.includes(status)) {
                    card.parentElement.style.display = 'block';
                } else {
                    card.parentElement.style.display = 'none';
                }
            }
        });
    }

    function cancelLeave(leaveId) {
        if (confirm('Are you sure you want to cancel this leave request?')) {
            // TODO: Send cancel request to server
            alert('Leave request cancelled successfully!');
        }
    }
</script>
