@{
    ViewData["Title"] = "About Us";
}

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12 text-center">
            <h2 class="page-heading">
                <i class="fas fa-info-circle me-2"></i>About Us
            </h2>
            <p class="text-muted">Learn more about Tasty Bites Delivery Partner Program</p>
        </div>
    </div>

    <!-- Company Info -->
    <div class="row mb-4">
        <div class="col-md-8 mx-auto">
            <div class="card">
                <div class="card-body">
                    <h4><i class="fas fa-utensils me-2 text-primary"></i>Tasty Bites</h4>
                    <p class="lead">Your trusted partner in food delivery excellence.</p>
                    <hr>
                    <p>Tasty Bites is a leading food delivery platform connecting customers with their favorite restaurants. Our delivery partner program provides flexible earning opportunities for dedicated individuals who want to be part of the growing food delivery ecosystem.</p>
                    
                    <h5 class="mt-4"><i class="fas fa-bullseye me-2 text-success"></i>Our Mission</h5>
                    <p>To provide fast, reliable, and efficient food delivery services while creating sustainable earning opportunities for our delivery partners.</p>
                    
                    <h5 class="mt-4"><i class="fas fa-eye me-2 text-info"></i>Our Vision</h5>
                    <p>To become the most trusted food delivery platform, known for excellent service quality and partner satisfaction.</p>
                    
                    <h5 class="mt-4"><i class="fas fa-star me-2 text-warning"></i>Why Join Us?</h5>
                    <ul>
                        <li>Flexible working hours</li>
                        <li>Competitive earnings with incentives</li>
                        <li>Weekly payouts</li>
                        <li>Insurance coverage</li>
                        <li>24/7 partner support</li>
                        <li>Growth opportunities</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats -->
    <div class="row mb-4">
        <div class="col-md-8 mx-auto">
            <div class="row text-center">
                <div class="col-md-3 mb-3">
                    <div class="card bg-primary text-white">
                        <div class="card-body">
                            <h3><i class="fas fa-users"></i></h3>
                            <h4>5000+</h4>
                            <p class="mb-0">Delivery Partners</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-3">
                    <div class="card bg-success text-white">
                        <div class="card-body">
                            <h3><i class="fas fa-city"></i></h3>
                            <h4>50+</h4>
                            <p class="mb-0">Cities</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-3">
                    <div class="card bg-info text-white">
                        <div class="card-body">
                            <h3><i class="fas fa-box"></i></h3>
                            <h4>1M+</h4>
                            <p class="mb-0">Deliveries</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-3">
                    <div class="card bg-warning text-dark">
                        <div class="card-body">
                            <h3><i class="fas fa-store"></i></h3>
                            <h4>10000+</h4>
                            <p class="mb-0">Restaurants</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
